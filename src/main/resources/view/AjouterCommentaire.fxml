<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" styleClass="root-commentaire" stylesheets="@focuskid.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.edu.esprit.controller.CommentaireController">
    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <!-- Titre -->
    <Label text="Gestion des commentaires" styleClass="section-title"/>

    <!-- Bouton Consulter -->
    <Button text="Consulter les commentaires" onAction="#ouvrirListe" styleClass="btn-consulter"/>

    <!-- Tableau des commentaires (caché initialement) -->
    <TableView fx:id="tableCommentaire" prefHeight="200" visible="false" managed="false" styleClass="comment-table">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colDate" text="Date" prefWidth="100"/>
            <TableColumn fx:id="colType" text="Type" prefWidth="120"/>
            <TableColumn fx:id="colTexte" text="Texte" prefWidth="250"/>
        </columns>
    </TableView>

    <!-- Formulaire -->
    <GridPane hgap="15" vgap="15" styleClass="form-grid">
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="80"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="ID Carnet :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="carnetIdTF" promptText="Saisir l'ID du carnet" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Date :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dateCommentaireDP" promptText="Choisir la date" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Type :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="typeCommentaireCB" promptText="Sélectionner un type" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Texte :" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextArea fx:id="texteCommentaireTA" promptText="Saisir le commentaire" prefHeight="80" wrapText="true" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <!-- Boutons d'action -->
    <HBox spacing="15" alignment="CENTER">
        <Button text="Ajouter" onAction="#ajouterCommentaire" styleClass="btn-action, btn-add"/>
        <Button text="Modifier" onAction="#modifierCommentaire" styleClass="btn-action, btn-edit"/>
        <Button text="Supprimer" onAction="#supprimerCommentaire" styleClass="btn-action, btn-delete"/>
    </HBox>
</VBox>