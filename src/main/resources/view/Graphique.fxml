<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.edu.esprit.controller.GraphiqueController"
            stylesheets="@focuskid.css"
            styleClass="root-page">

    <!-- ===== HEADER ===== -->
    <top>
        <VBox styleClass="dashboard-header" alignment="CENTER" spacing="6">
            <Label text="📊 Dashboard Graphiques" styleClass="dashboard-title"/>
            <Label text="Suivez l'évolution de votre enfant" styleClass="dashboard-subtitle"/>
        </VBox>
    </top>

    <!-- ===== CENTRE ===== -->
    <center>
        <VBox spacing="18" alignment="TOP_CENTER" style="-fx-padding: 10 30 10 30;">

            <!-- Boutons toggle Concentration / Matière -->
            <HBox spacing="14" alignment="CENTER" style="-fx-padding: 6 0 6 0;">
                <Button fx:id="btnConcentration"
                        styleClass="toggle-btn-active"
                        text="📈  Concentration"
                        onAction="#afficherConcentration"/>
                <Button fx:id="btnMatiere"
                        styleClass="toggle-btn"
                        text="📊  Temps par matière"
                        onAction="#afficherMatiere"/>
            </HBox>

            <!-- Zone graphique (affiche l'un ou l'autre) -->
            <StackPane fx:id="chartContainer" styleClass="white-board"
                       VBox.vgrow="ALWAYS"
                       prefHeight="520">

                <!-- LineChart — Concentration -->
                <LineChart fx:id="chartConcentration"
                           animated="true"
                           createSymbols="true"
                           prefWidth="1150"
                           prefHeight="480"
                           visible="true">
                    <xAxis><CategoryAxis label="Date"/></xAxis>
                    <yAxis><NumberAxis label="Concentration" lowerBound="0" upperBound="5" tickUnit="1"/></yAxis>
                </LineChart>

                <!-- BarChart — Matières -->
                <BarChart fx:id="chartMatiere"
                          animated="true"
                          prefWidth="1150"
                          prefHeight="480"
                          visible="false">
                    <xAxis><CategoryAxis label="Matière"/></xAxis>
                    <yAxis><NumberAxis label="Durée (min)"/></yAxis>
                </BarChart>

            </StackPane>

        </VBox>
    </center>

    <!-- ===== BAS — Boutons d'action ===== -->
    <bottom>
        <HBox spacing="18" alignment="CENTER" styleClass="bottom-action-bar">
            <padding><Insets top="14" bottom="20" left="20" right="20"/></padding>

            <Button fx:id="refreshButton"
                    styleClass="action-btn-green"
                    onAction="#rafraichir">
                <graphic>
                    <HBox alignment="CENTER" spacing="8">
                        <Label text="🔄" style="-fx-font-size:18px;"/>
                        <Label text="Rafraîchir" styleClass="btn-text"/>
                    </HBox>
                </graphic>
            </Button>

            <Button fx:id="exportButton"
                    styleClass="action-btn-blue"
                    onAction="#exporterPDF">
                <graphic>
                    <HBox alignment="CENTER" spacing="8">
                        <Label text="📄" style="-fx-font-size:18px;"/>
                        <Label text="Exporter PDF" styleClass="btn-text"/>
                    </HBox>
                </graphic>
            </Button>

            <Button fx:id="statsButton"
                    styleClass="action-btn-orange"
                    onAction="#ouvrirStats">
                <graphic>
                    <HBox alignment="CENTER" spacing="8">
                        <Label text="📈" style="-fx-font-size:18px;"/>
                        <Label text="Statistiques" styleClass="btn-text"/>
                    </HBox>
                </graphic>
            </Button>

            <Button fx:id="closeButton"
                    styleClass="action-btn-red"
                    onAction="#fermerFenetre">
                <graphic>
                    <HBox alignment="CENTER" spacing="8">
                        <Label text="✖" style="-fx-font-size:18px;"/>
                        <Label text="Fermer" styleClass="btn-text"/>
                    </HBox>
                </graphic>
            </Button>

        </HBox>
    </bottom>

</BorderPane>
