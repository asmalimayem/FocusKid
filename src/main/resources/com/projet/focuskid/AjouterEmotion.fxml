<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.shape.Circle?>
<StackPane styleClass="main-background"
           stylesheets="@style.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.projet.focuskid.controllers.AjouterEmotion">

    <BorderPane>
        <!-- TOP: Profil utilisateur avec animation -->
        <top>
            <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 15;">
                <VBox alignment="CENTER_RIGHT" spacing="2">
                    <Label styleClass="user-name" text="Lucas" />
                    <HBox alignment="CENTER" spacing="5">
                        <ImageView fitHeight="20" fitWidth="20">
                            <image><Image url="@star.png" /></image>
                        </ImageView>
                        <Label styleClass="user-points" text="1250 points" />
                    </HBox>
                </VBox>
                <StackPane styleClass="avatar-container">
                    <Circle styleClass="avatar-circle" radius="30" />
                    <ImageView fitHeight="50" fitWidth="50" styleClass="avatar-image">
                        <image><Image url="@avatar.png" /></image>
                    </ImageView>
                </StackPane>
            </HBox>
        </top>

        <!-- LEFT: Sidebar avec animations -->
        <!-- Sidebar avec les bons fx:id -->
        <left>
            <VBox alignment="CENTER" spacing="25" styleClass="sidebar">
                <Button fx:id="btnAdd" styleClass="side-button">  <!-- ID = btnAdd -->
                    <graphic>
                        <ImageView fitWidth="35" preserveRatio="true" styleClass="side-icon">
                            <image><Image url="@plus.png" /></image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="btnList" styleClass="side-button">  <!-- ID = btnList -->
                    <graphic>
                        <ImageView fitWidth="35" preserveRatio="true" styleClass="side-icon">
                            <image><Image url="@list.png" /></image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="btnRefresh" styleClass="side-button">  <!-- ID = btnRefresh -->
                    <graphic>
                        <ImageView fitWidth="35" preserveRatio="true" styleClass="side-icon">
                            <image><Image url="@refresh.png" /></image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="btnDelete" styleClass="side-button">  <!-- ID = btnDelete -->
                    <graphic>
                        <ImageView fitWidth="35" preserveRatio="true" styleClass="side-icon">
                            <image><Image url="@trash.png" /></image>
                        </ImageView>
                    </graphic>
                </Button>
            </VBox>
        </left>

        <!-- CENTER: Contenu principal interactif -->
        <!-- CENTER: Contenu principal interactif -->
        <center>
            <StackPane styleClass="main-content-container">
                <VBox styleClass="white-board" spacing="20">
                    <padding>
                        <Insets top="25" right="25" bottom="25" left="25" />
                    </padding>

                    <!-- Titre animé -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <ImageView fitHeight="40" fitWidth="40">
                            <image><Image url="@welcome.png" /></image>
                        </ImageView>
                        <Text styleClass="welcome-text" text="Bonjour Lucas ! Prêt pour l'aventure ?" />
                    </HBox>

                    <!-- Formulaire et widgets -->
                    <!-- Formulaire Émotion -->
                    <VBox alignment="CENTER" spacing="30" style="-fx-padding: 30;">

                        <!-- Champs Nom + Icône sur la même ligne -->
                        <HBox alignment="CENTER" spacing="40">
                            <!-- Champ Nom -->
                            <VBox spacing="5" alignment="CENTER_LEFT">
                                <Label text="Nom de l'émotion" styleClass="form-label"/>
                                <StackPane styleClass="input-card" prefWidth="300" prefHeight="60">
                                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 15;">
                                        <ImageView fitHeight="40" fitWidth="40">
                                            <image><Image url="@verifier.png"/></image>
                                        </ImageView>
                                        <TextField fx:id="txtnom" promptText="Nom" styleClass="input-field"/>
                                    </HBox>
                                </StackPane>
                            </VBox>

                            <!-- Champ Icône -->
                            <VBox spacing="5" alignment="CENTER_LEFT">
                                <Label text="Nom du fichier icône" styleClass="form-label"/>
                                <StackPane styleClass="input-card" prefWidth="300" prefHeight="60">
                                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 15;">
                                        <ImageView fitHeight="40" fitWidth="40">
                                            <image><Image url="@yeux.png"/></image>
                                        </ImageView>
                                        <TextField fx:id="txticone" promptText="Icône" styleClass="input-field"/>
                                    </HBox>
                                </StackPane>
                            </VBox>
                        </HBox>

                        <!-- Bouton Ajouter centré en dessous -->
                        <Button text="Ajouter" styleClass="add-button" onAction="#addEmotion" prefWidth="200" prefHeight="50"/>
                    </VBox>
                    <!-- Message du jour -->
                    <HBox styleClass="daily-message" alignment="CENTER" spacing="10">
                        <ImageView fitHeight="25" fitWidth="25">
                            <image><Image url="@info.png" /></image>
                        </ImageView>
                        <Label fx:id="emotionMessage"
                               text="Ajouter emotion"
                               styleClass="tip-text" />
                    </HBox>
                </VBox>
            </StackPane>
        </center>
        <!-- BOTTOM: Navigation améliorée -->
        <bottom>
            <VBox>
                <!-- Barre de navigation avec animations -->
                <HBox alignment="CENTER" spacing="20" styleClass="bottom-nav">
                    <VBox alignment="CENTER" styleClass="nav-item" fx:id="navCours">
                        <StackPane styleClass="nav-icon-container">
                            <Circle styleClass="nav-icon-bg" radius="35" />
                            <ImageView fitHeight="50" preserveRatio="true" styleClass="nav-icon">
                                <image><Image url="@cours.png" /></image>
                            </ImageView>
                        </StackPane>
                        <Label styleClass="nav-label" text="Mes cours" />
                    </VBox>

                    <VBox alignment="CENTER" styleClass="nav-item" fx:id="navExercices">
                        <StackPane styleClass="nav-icon-container">
                            <Circle styleClass="nav-icon-bg" radius="35" />
                            <ImageView fitHeight="50" preserveRatio="true" styleClass="nav-icon">
                                <image><Image url="@quiz.png" /></image>
                            </ImageView>
                        </StackPane>
                        <Label styleClass="nav-label" text="Exercices" />
                    </VBox>

                    <VBox alignment="CENTER" styleClass="nav-item" fx:id="navParents">
                        <StackPane styleClass="nav-icon-container">
                            <Circle styleClass="nav-icon-bg" radius="35" />
                            <ImageView fitHeight="50" preserveRatio="true" styleClass="nav-icon">
                                <image><Image url="@famille.png" /></image>
                            </ImageView>
                        </StackPane>
                        <Label styleClass="nav-label" text="Parents" />
                    </VBox>

                    <VBox alignment="CENTER" styleClass="nav-item" fx:id="navGamification">
                        <StackPane styleClass="nav-icon-container">
                            <Circle styleClass="nav-icon-bg" radius="35" />
                            <ImageView fitHeight="50" preserveRatio="true" styleClass="nav-icon">
                                <image><Image url="@puzzle.png" /></image>
                            </ImageView>
                        </StackPane>
                        <Label styleClass="nav-label" text="Gammification" />
                    </VBox>

                    <VBox alignment="CENTER" styleClass="nav-item" fx:id="navCalme">
                        <StackPane styleClass="nav-icon-container">
                            <Circle styleClass="nav-icon-bg, calm-bg" radius="35" />
                            <ImageView fitHeight="50" preserveRatio="true" styleClass="nav-icon">
                                <image><Image url="@meditation.png" /></image>
                            </ImageView>
                        </StackPane>
                        <Label styleClass="nav-label" text="Bulle de Calme" />
                    </VBox>

                    <VBox alignment="CENTER" styleClass="nav-item" fx:id="navEmotions">
                        <StackPane styleClass="nav-icon-container">
                            <Circle styleClass="nav-icon-bg" radius="35" />
                            <ImageView fitHeight="50" preserveRatio="true" styleClass="nav-icon">
                                <image><Image url="@emotions.png" /></image>
                            </ImageView>
                        </StackPane>
                        <Label styleClass="nav-label-active" text="Émotions" />
                    </VBox>
                </HBox>

                <!-- Indicateur de sélection animé -->
                <HBox alignment="CENTER" styleClass="nav-indicator">
                    <Circle radius="5" fill="#1a1a8b" />
                </HBox>
            </VBox>
        </bottom>
    </BorderPane>
</StackPane>