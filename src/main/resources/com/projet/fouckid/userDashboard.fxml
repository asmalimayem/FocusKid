<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<StackPane fx:id="rootPane" styleClass="main-background" stylesheets="@style.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.projet.fouckid.controllers.UserDashboardController">

    <BorderPane style="-fx-background-color: transparent;">

        <!-- TOP: Barre de bienvenue -->
        <top>
            <HBox alignment="CENTER" spacing="25" styleClass="top-bar" prefHeight="100">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label text="🎮📚" style="-fx-font-size: 50px;"/>
                    <Label text="FocusKid" style="-fx-font-family: 'Comic Sans MS'; -fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1a1a8b;"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="8">
                    <Label fx:id="welcomeLabel" text="Bonjour 👋" style="-fx-font-family: 'Comic Sans MS'; -fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a8b;"/>
                    <HBox spacing="10" alignment="CENTER">
                        <Label text="🏆" style="-fx-font-size: 24px;"/>
                        <Label fx:id="totalPointsLabel" text="0" style="-fx-font-family: 'Comic Sans MS'; -fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ff8c00;"/>
                        <Label text="points" style="-fx-font-family: 'Comic Sans MS'; -fx-font-size: 16px; -fx-text-fill: #666;"/>
                    </HBox>
                </VBox>
                <Button fx:id="btnLogout" text="🚪" onAction="#handleLogout"
                        style="-fx-background-color: #FF7043; -fx-text-fill: white; -fx-font-size: 24px; -fx-background-radius: 25; -fx-min-width: 50; -fx-min-height: 50;"/>
            </HBox>
        </top>

        <!-- CENTER: Liste des jeux -->
        <center>
            <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: rgba(255,255,255,0.95); -fx-background-radius: 40; -fx-border-radius: 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0.2, 0, 5);">

                <HBox alignment="CENTER_LEFT" spacing="20">
                    <Label text="🎮" style="-fx-font-size: 50px;"/>
                    <Label text="Mes Jeux" style="-fx-font-family: 'Comic Sans MS'; -fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1a1a8b;"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnRefresh" text="🔄" onAction="#handleRefresh"
                            style="-fx-background-color: #ffb32b; -fx-text-fill: white; -fx-font-size: 24px; -fx-background-radius: 25; -fx-min-width: 50; -fx-min-height: 50;"/>
                </HBox>

                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <FlowPane fx:id="gamesContainer" hgap="30" vgap="30" alignment="TOP_CENTER"
                              style="-fx-padding: 20;"/>
                </ScrollPane>

                <VBox fx:id="emptyMessage" alignment="CENTER" spacing="20" visible="false" managed="false">
                    <Label text="😢" style="-fx-font-size: 80px;"/>
                    <Label text="Aucun jeu disponible pour le moment" style="-fx-font-family: 'Comic Sans MS'; -fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a1a8b;"/>
                    <Label text="Reviens plus tard !" style="-fx-font-family: 'Comic Sans MS'; -fx-font-size: 18px; -fx-text-fill: #ff8c00;"/>
                </VBox>

            </VBox>
        </center>

        <!-- BOTTOM: Navigation simple -->
        <bottom>
            <HBox alignment="CENTER" style="-fx-padding: 20; -fx-background-color: rgba(255,255,255,0.9); -fx-background-radius: 30 30 0 0;">
                <Label text="⭐ Choisis un jeu et commence à jouer ! ⭐"
                       style="-fx-font-family: 'Comic Sans MS'; -fx-font-size: 18px; -fx-text-fill: #ff8c00; -fx-font-weight: bold;"/>
            </HBox>
        </bottom>

    </BorderPane>
</StackPane>